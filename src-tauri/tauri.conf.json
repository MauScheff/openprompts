{
  "$schema": "https://schema.tauri.app/config/2.5.0",
  "productName": "webapp",
  "version": "1.0.0",
  "identifier": "com.tauri.webapp",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5001",
    "frontendDist": "../public"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "webapp",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "transparent": false,
        "maximized": false
      }
    ]
  },
  "bundle": {
    "icon": [],
    "resources": [],
    "externalBin": []
  },
  "plugins": {}
}